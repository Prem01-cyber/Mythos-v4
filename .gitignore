# Secrets
.env

# ExploitDB — large git repo clone, re-clone on target machine
exploitdb/

# Raw generated data — re-generate on target machine
raw/

# Processed training datasets — re-generate via prepare_data.py
processed/*.jsonl

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

# Virtual environments
venv/
.venv/
env/

# Model outputs and checkpoints — too large for git
# Use adapters/* (not adapters/) so git can see inside the directory for exceptions
adapters/*
outputs/
checkpoints/
*.safetensors
*.bin
*.ckpt
adapter_config.json
adapter_model/

# Router classifier is small (525KB MLP head) — track in git so cloud gets it on pull.
# The !negations only work because we use adapters/* above, not adapters/.
!adapters/router_classifier
!adapters/router_classifier/label_map.json
!adapters/router_classifier/encoder_name.txt
!adapters/router_classifier/stats.json
!adapters/router_classifier/model.pt

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# HuggingFace cache
.cache/
sync_mythos.sh
results
